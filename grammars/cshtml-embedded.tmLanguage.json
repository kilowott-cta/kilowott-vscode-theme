{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "kilowott.cshtml.embedded.injection",
  "injectionSelector": "L:text.aspnetcorerazor, L:text.html.cshtml, L:text.html.razor",
  "patterns": [
    { "include": "#script-block" },
    { "include": "#style-block" }
  ],
  "repository": {
    "script-block": {
      "begin": "(?i)(<)(script)\\b(?![^>]*\\bsrc\\s*=)([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": {
          "patterns": [
            {
              "match": "(?i)\\b([a-z][-a-z0-9]*)\\s*(=)\\s*(\"[^\"]*\"|'[^']*'|[^\\s>]+)",
              "captures": {
                "1": { "name": "entity.other.attribute-name.html" },
                "2": { "name": "punctuation.separator.key-value.html" },
                "3": { "name": "string.quoted.html" }
              }
            }
          ]
        },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(?i)(</)(script)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "name": "meta.embedded.block.html",
      "contentName": "source.js",
      "patterns": [
        { "include": "source.js" }
      ]
    },
    "style-block": {
      "begin": "(?i)(<)(style)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": {
          "patterns": [
            {
              "match": "(?i)\\b([a-z][-a-z0-9]*)\\s*(=)\\s*(\"[^\"]*\"|'[^']*'|[^\\s>]+)",
              "captures": {
                "1": { "name": "entity.other.attribute-name.html" },
                "2": { "name": "punctuation.separator.key-value.html" },
                "3": { "name": "string.quoted.html" }
              }
            }
          ]
        },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(?i)(</)(style)\\s*(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "name": "meta.embedded.block.html",
      "contentName": "source.css",
      "patterns": [
        { "include": "source.css" }
      ]
    }
  }
}
